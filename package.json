{
  "name": "converse.js",
  "version": "14.0.0-beta.4",
  "description": "Browser based XMPP chat client",
  "type": "module",
  "workspaces": [
    "src/headless",
    "src/log"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./src/types/index.d.ts",
        "default": "./dist/converse.js"
      }
    },
    "./dist/*": "./dist/*",
    "./shared/*": "./src/shared/*"
  },
  "types": "./src/types/index.d.ts",
  "browser": "dist/converse.js",
  "main": "dist/converse.js",
  "files": [
    "CHANGES.md",
    "LICENSE.txt",
    "README.md",
    "COPYRIGHT",
    "dist/",
    "docs/**/*.md",
    "docs/**/*.mdx",
    "sass/**/*.scss",
    "src/**/*.html",
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.ts.map",
    "src/**/*.json",
    "src/**/*.md",
    "src/**/*.po",
    "src/**/*.pot",
    "src/**/*.scss",
    "src/**/*.svg",
    "src/**/*.txt",
    "3rdparty/*.js"
  ],
  "scripts": {
    "build": "npm run build:website-min-css && npm run build:headless && npm run build:main",
    "build:main": "rspack build --config rspack/rspack.build.js && npm run build:converse-min-css",
    "build:converse-min-css": "npx clean-css-cli dist/converse.css > dist/converse.min.css",
    "build:headless": "rspack build --config rspack/rspack.headless.js",
    "build:website-css": "sass --quiet --load-path=node_modules src/shared/styles/website.scss dist/website.css",
    "build:website-min-css": "npm run build:website-css && npx clean-css-cli dist/website.css > dist/website.min.css",
    "cdn": "ASSET_PATH=https://cdn.conversejs.org/dist/ npm run build",
    "clean": "rm -rf node_modules dist *.zip src/headless/dist src/headless/node_modules",
    "dev": "DROP_DEBUGGER=false npm run dev:headless && npm run dev:main",
    "dev:headless": "DROP_DEBUGGER=false npm run build:headless -- --mode=development",
    "dev:main": "DROP_DEBUGGER=false rspack build --config rspack/rspack.build.js --mode=development && npm run build:converse-min-css",
    "devserver": "npm run dev:headless && npx rspack serve --config rspack/rspack.serve.js",
    "dist": "DROP_DEBUGGER=true npm run build",
    "docs:build": "cd docs && npm run build",
    "docs:dev": "cd docs && npm run dev",
    "lint": "eslint src/**/*.js",
    "nodeps": "rspack build --config rspack/rspack.nodeps.js",
    "serve": "http-server -c-1",
    "serve-tls": "http-server -S -C certs/chat.example.org.crt -K certs/chat.example.org.key",
    "test": "vitest run --project main",
    "test:all": "vitest run",
    "test:browser": "vitest --project main --browser.headless=false",
    "test:headless": "vitest run --project headless",
    "test:headless:browser": "vitest --project headless --browser.headless=false",
    "types": "tsc -p ./src/log/tsconfig.json && tsc -p ./src/headless/tsconfig.json && tsc",
    "types:check": "tsc --noEmit",
    "watch": "concurrently \"npm run watch:headless\" \"npm run watch:main\"",
    "watch:headless": "DROP_DEBUGGER=false rspack --watch --config rspack/rspack.headless.js --mode=development",
    "watch:main": "DROP_DEBUGGER=false rspack --watch --config rspack/rspack.build.js --mode=development"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/conversejs/converse.js.git"
  },
  "keywords": [
    "converse.js",
    "XMPP",
    "Jabber",
    "chat",
    "messaging",
    "chatrooms",
    "webchat"
  ],
  "author": {
    "name": "JC Brand",
    "email": "jc@opkode.com"
  },
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/conversejs/converse.js/issues"
  },
  "engines": {
    "browser": "*"
  },
  "devDependencies": {
    "@converse/headless": "file:src/headless",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@rspack/cli": "^2.0.4",
    "@rspack/core": "^2.0.4",
    "@rspack/dev-server": "^2.0.1",
    "@types/bootstrap": "^5.2.10",
    "@types/lodash-es": "^4.17.12",
    "@types/sizzle": "^2.3.8",
    "@types/webappsec-credential-management": "^0.6.8",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "autoprefixer": "^10.4.5",
    "clean-css-cli": "^5.6.2",
    "concurrently": "^10.0.3",
    "css-loader": "^7.1.2",
    "eslint": "^10.0.2",
    "fast-text-encoding": "^1.0.3",
    "globals": "^17.3.0",
    "http-server": "^14.1.0",
    "imports-loader": "^5.0.0",
    "install": "^0.13.0",
    "minify-html-literals-loader": "^1.1.1",
    "minimist": "^1.2.6",
    "playwright": "^1.61.0",
    "po-loader": "0.7.0",
    "po2json": "1.0.0-beta-3",
    "postcss": "^8.4.16",
    "postcss-loader": "^8.1.1",
    "sass": "^1.86.2",
    "sass-loader": "^17.0.0",
    "sirv": "^3.0.2",
    "style-loader": "^4.0.0",
    "typescript": "5.6.2",
    "vitest": "^4.1.9",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@babel/runtime": "^7.27.6",
    "@converse/log": "file:src/log",
    "bootstrap": "^5.3.3",
    "dompurify": "^3.0.8",
    "favico.js-slevomat": "^0.3.11",
    "gifuct-js": "^2.1.2",
    "hsluv": "^1.0.1",
    "jed": "1.1.1",
    "lit": "^3.1.4",
    "localforage-webextensionstorage-driver": "^3.0.0",
    "lodash-es": "^4.17.21",
    "pluggable.js": "^3.0.1",
    "prettier": "^3.2.5",
    "sizzle": "^2.3.5",
    "sprintf-js": "^1.1.2"
  },
  "resolutions": {
    "autoprefixer": "10.4.5"
  }
}
