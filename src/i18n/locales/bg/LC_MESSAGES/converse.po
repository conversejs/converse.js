msgstr "Вашето кратко име беше автоматично установено на %1$s"

#: dist/converse-no-dependencies.js:62905
msgid "You have been banned from this groupchat"
msgstr "Достъпът Ви до този групов чат е забранен"

#. XXX: Note the triple underscore function and not double underscore.
#: dist/converse-no-dependencies.js:62907
#, javascript-format
msgid "Your nickname has been changed to %1$s"
msgstr "Краткото ви име беше променено на %1$s"

#: dist/converse-no-dependencies.js:62908
msgid "You have been kicked from this groupchat"
msgstr "Вие бяхте отстранени от този групов чат"

#: dist/converse-no-dependencies.js:62909
msgid ""
"You have been removed from this groupchat because of an affiliation change"
msgstr "Бяхте премахнати от този групов чат поради промяна в принадлежността"

#: dist/converse-no-dependencies.js:62910
msgid ""
"You have been removed from this groupchat because it has changed to members-"
