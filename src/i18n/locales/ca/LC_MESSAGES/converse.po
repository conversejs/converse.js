#: dist/converse-no-dependencies.js:57468
#, javascript-format
msgid ""
"Error: the \"%1$s\" command takes two arguments, the user's nickname and "
"optionally a reason."
msgstr ""
"Error: l'ordre «%1$s» accepta dos paràmetres, l'àlies de l'usuari i una raó "
"opcional."

