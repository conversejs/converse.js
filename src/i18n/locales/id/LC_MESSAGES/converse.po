#: dist/converse-no-dependencies.js:106670
#: dist/converse-no-dependencies.js:117828
#: dist/converse-no-dependencies.js:128463
#: dist/converse-no-dependencies.js:128473
#: dist/converse-no-dependencies.js:132045
#: dist/converse-no-dependencies.js:137750
#: dist/converse-no-dependencies.js:141667
msgid "Error"
msgstr "Kesalahan"

#: dist/converse-no-dependencies.js:59895
msgid ""
"Sorry, no devices found to which we can send an OMEMO encrypted message."
msgstr ""
"Maaf, tidak ada perangkat yang dapat kami gunakan untuk mengirim pesan "
"terenkripsi OMEMO."

#: dist/converse-no-dependencies.js:59905
msgid ""
"Cannot use OMEMO in this groupchat — it must be non-anonymous and members-"
"only."
msgstr ""

#: dist/converse-no-dependencies.js:60858
msgid ""
"This is an OMEMO encrypted message which your client doesn’t seem to "
"support. Find more information on https://conversations.im/omemo"
msgstr ""
"Ini adalah pesan terenkripsi OMEMO yang tampaknya tidak didukung oleh klien "
"Anda. Temukan informasi lebih lanjut tentang https://conversations.im/omemo"

#: dist/converse-no-dependencies.js:60991
#, javascript-format
msgid ""
"%1$s doesn't appear to have a client that supports OMEMO. Encrypted chat "
"will no longer be possible in this grouchat."
msgstr ""
"%1$s tampaknya tidak memiliki klien yang mendukung OMEMO. Obrolan "
"terenkripsi tidak lagi dapat dilakukan di obrolan grup ini."

#: dist/converse-no-dependencies.js:63381
#, javascript-format
msgid "Sorry, an error occurred while trying to add %1$s as a contact."
msgstr "Maaf, terjadi kesalahan saat mencoba menambahkan %1$s sebagai kontak."

#: dist/converse-no-dependencies.js:63650
msgid "This client does not allow presence subscriptions"
msgstr "Klien ini tidak mengizinkan langganan berkelanjutan"

#: dist/converse-no-dependencies.js:63896
msgid "Unsaved contacts"
msgstr "Kontak yang belum disimpan"

#: dist/converse-no-dependencies.js:63897
msgid "My contacts"
msgstr "Kontak"

#: dist/converse-no-dependencies.js:63898
msgid "Pending contacts"
msgstr "Kontak tertunda"

#: dist/converse-no-dependencies.js:63899
msgid "Contact requests"
msgstr "Permintaan kontak"

#: dist/converse-no-dependencies.js:63900
msgid "Ungrouped"
msgstr "Tidak dikelompokkan"

#: dist/converse-no-dependencies.js:63901
#: dist/converse-no-dependencies.js:109292
msgid "New messages"
msgstr "Pesan baru"

#: dist/converse-no-dependencies.js:65181
msgid "me"
msgstr "saya"

#: dist/converse-no-dependencies.js:68336
msgid "Could not automatically determine a connection URL"
msgstr "Tidak dapat secara otomatis menentukan URL koneksi"

#: dist/converse-no-dependencies.js:68672
#: dist/converse-no-dependencies.js:68725
msgid "An error occurred while connecting to the chat server."
msgstr "Maaf, terjadi kesalahan saat mengubungi chat server."

#: dist/converse-no-dependencies.js:68732
msgid "Your XMPP address and/or password is incorrect. Please try again."
msgstr "Alamat XMPP dan/atau kata sandi anda salah. Silakan coba lagi."

#: dist/converse-no-dependencies.js:68741
#, javascript-format
msgid "We could not connect to %1$s, is your XMPP address correct?"
msgstr "Kami tidak dapat terhubung ke %1$s, apakah alamat XMPP Anda benar?"

#: dist/converse-no-dependencies.js:68743
msgid "The XMPP server rejected the connection because of a policy violation"
msgstr "Server XMPP menolak koneksi karena pelanggaran kebijakan"

#: dist/converse-no-dependencies.js:68745
msgid "The XMPP server did not offer a supported authentication mechanism"
msgstr "Peladen XMPP tak menawarkan mekanisme otentikasi yang didukung"

#: dist/converse-no-dependencies.js:69893
msgid "Undecryptable OMEMO message"
msgstr "Pesan OMEMO tidak dapat dienkripsi"

#: dist/converse-no-dependencies.js:69993
msgid "Sorry, could not determine upload URL."
msgstr "Maaf, tidak dapat menentukan URL unggahan."

#: dist/converse-no-dependencies.js:70010
msgid "Sorry, could not determine file upload URL."
msgstr "Maaf, tidak dapat menentukan URL berkas unggahan."

#: dist/converse-no-dependencies.js:70086
#, javascript-format
msgid ""
"Sorry, could not successfully upload your file. Your server’s response: "
"\"%1$s\""
msgstr ""
"Maaf, kami tidak dapat mengunggah berkas Anda dengan sukses. Tanggapan "
"server Anda: “%1$s”"

#: dist/converse-no-dependencies.js:70088
msgid "Sorry, could not successfully upload your file."
msgstr "Maaf, kami tidak dapat mengunggah berkas Anda dengan sukses."

#: dist/converse-no-dependencies.js:70906
#: dist/converse-no-dependencies.js:70924
msgid "Sorry, looks like file upload is not supported by your server."
msgstr "Maaf, sepertinya unggahan berkas tidak didukung oleh server Anda."

#: dist/converse-no-dependencies.js:70955
#, javascript-format
msgid ""
"The size of your file, %1$s, exceeds the maximum allowed by your server."
msgstr ""
"Ukuran berkas Anda, %1$s, melebihi batas maksimum yang diizinkan oleh server "
"Anda."

#: dist/converse-no-dependencies.js:70955
