#: dist/converse-no-dependencies.js:53255
msgid ""
"Sorry, no devices found to which we can send an OMEMO encrypted message."
msgstr ""
"Scusa, nessun dispositivo trovato al quale possiamo inviare un messaggio "
"criptato OMEMO."

#: dist/converse-no-dependencies.js:53527
msgid ""
"This is an OMEMO encrypted message which your client doesn’t seem to "
"support. Find more information on https://conversations.im/omemo"
msgstr ""
"Questo è un messaggio criptato OMEMO che il tuo client non sembra "
"supportare. Trova più informazioni su https://conversations.im/omemo"

#: dist/converse-no-dependencies.js:53629
#, javascript-format
msgid ""
"%1$s doesn't appear to have a client that supports OMEMO. Encrypted chat "
"will no longer be possible in this grouchat."
msgstr ""
"%1$s non sembra abbia un client che supporta OMEMO. Non sembra sia possibile "
"avere una conversazione criptata in questa conversazione di gruppo."

#: dist/converse-no-dependencies.js:55468
#, javascript-format
msgid "Sorry, an error occurred while trying to add %1$s as a contact."
msgstr ""
"Spiacenti, si è verificato un errore durante il tentativo di aggiungere %1$s "
"come contatto."

#: dist/converse-no-dependencies.js:55739
msgid "This client does not allow presence subscriptions"
msgstr "Questo client non consente sottoscrizioni di presenza"

#: dist/converse-no-dependencies.js:55978
msgid "Unsaved contacts"
msgstr "Contatti non salvati"

#: dist/converse-no-dependencies.js:55979
msgid "My contacts"
msgstr "I miei contatti"

#: dist/converse-no-dependencies.js:55980
msgid "Pending contacts"
msgstr "Contatti in attesa"

#: dist/converse-no-dependencies.js:55981
msgid "Contact requests"
msgstr "Richieste di contatto"

#: dist/converse-no-dependencies.js:55982
msgid "Ungrouped"
msgstr "Senza Gruppo"

#: dist/converse-no-dependencies.js:55983
#: dist/converse-no-dependencies.js:103770
msgid "New messages"
msgstr "Nuovi messaggi"

#: dist/converse-no-dependencies.js:57273
msgid "me"
msgstr "me"

#: dist/converse-no-dependencies.js:60302
msgid "Could not automatically determine a connection URL"
msgstr "Impossibile determinare automaticamente un URL di connessione"

#: dist/converse-no-dependencies.js:60638
#: dist/converse-no-dependencies.js:60691
msgid "An error occurred while connecting to the chat server."
msgstr "Si è verificato un errore durante la connessione al server."

#: dist/converse-no-dependencies.js:60698
msgid "Your XMPP address and/or password is incorrect. Please try again."
msgstr "Il tuo indirizzo XMPP e/o la tua password sono sbagliati. Riprova."

#: dist/converse-no-dependencies.js:60707
#, javascript-format
msgid "We could not connect to %1$s, is your XMPP address correct?"
msgstr ""
"Non siamo riusciti a connetterci a %1$s, il tuo indirizzo XMPP è corretto?"

#: dist/converse-no-dependencies.js:60709
msgid "The XMPP server rejected the connection because of a policy violation"
msgstr ""
"Il server XMPP ha rifiutato la connessione a causa di una violazione della "
"policy"

#: dist/converse-no-dependencies.js:60711
msgid "The XMPP server did not offer a supported authentication mechanism"
msgstr ""
"Il server XMPP non ha offerto un meccanismo di autenticazione supportato"

#: dist/converse-no-dependencies.js:61844
msgid "Undecryptable OMEMO message"
msgstr "Messaggio OMEMO non decifrabile"

#: dist/converse-no-dependencies.js:61934
msgid "Sorry, could not determine upload URL."
msgstr "Spiacente, impossibile determinare l'URL di caricamento."

#: dist/converse-no-dependencies.js:61951
msgid "Sorry, could not determine file upload URL."
msgstr "Spiacente, impossibile determinare l'URL di caricamento del file."

#: dist/converse-no-dependencies.js:62027
#, javascript-format
msgid ""
"Sorry, could not successfully upload your file. Your server’s response: "
"\"%1$s\""
msgstr ""
"Spiacenti, non è stato possibile caricare correttamente il file. Risposta "
"del server: \"%1$s\""

#: dist/converse-no-dependencies.js:62029
msgid "Sorry, could not successfully upload your file."
msgstr "Spiacenti, non è stato possibile caricare correttamente il file."

#: dist/converse-no-dependencies.js:62775
#: dist/converse-no-dependencies.js:62793
msgid "Sorry, looks like file upload is not supported by your server."
msgstr ""
"Spiacente, sembra che il caricamento dei file non sia supportato dal tuo "
"server."

#: dist/converse-no-dependencies.js:62824
#, javascript-format
msgid ""
"The size of your file, %1$s, exceeds the maximum allowed by your server."
msgstr ""
"La dimensione del file, %1$s, supera il massimo consentito dal tuo server."

#: dist/converse-no-dependencies.js:62824
#, javascript-format
msgid ""
"The size of your file, %1$s, exceeds the maximum allowed by your server, "
"which is %2$s."
msgstr ""
"La dimensione del tuo file, %1$s, supera il massimo consentito dal tuo "
"server, che è %2$s."

#: dist/converse-no-dependencies.js:63405
