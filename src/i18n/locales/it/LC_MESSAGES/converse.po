msgstr "Server remoto non trovato"

#: dist/converse-no-dependencies.js:59416
msgid "You're not allowed to enter this groupchat"
msgstr "Non ti è permesso entrare in questa conversazione di gruppo"

#: dist/converse-no-dependencies.js:59419
msgid "An error happened while trying to enter this groupchat"
msgstr ""
"Si è verificato un errore durante l'accesso a questa conversazione di gruppo"

#: dist/converse-no-dependencies.js:60647
#, javascript-format
msgid "%1$s has gone offline"
msgstr "%1$s si è disconnesso"

#: dist/converse-no-dependencies.js:60651
#, javascript-format
msgid "%1$s is busy"
msgstr "%1$s è occupato"

#: dist/converse-no-dependencies.js:60653
#, javascript-format
