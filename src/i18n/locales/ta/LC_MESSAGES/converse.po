msgstr "%1$s தட்டச்சு செய்கின்றன"

#: dist/converse-no-dependencies.js:52872
#, javascript-format
msgid "%1$s have stopped typing"
msgstr "%1$s தட்டச்சு செய்வதை நிறுத்திவிட்டன"

#: dist/converse-no-dependencies.js:52874
#, javascript-format
