msgstr "%1$s இனி மதிப்பீட்டாளர்கள் அல்ல"

#: dist/converse-no-dependencies.js:48023
#, javascript-format
msgid "%1$s have been given voices"
msgstr "%1$s க்கு குரல்கள் வழங்கப்பட்டுள்ளன"

#: dist/converse-no-dependencies.js:48025
#, javascript-format
