msgstr "%1$s குழுமத்திற்குள் நுழைந்தன"

#: dist/converse-no-dependencies.js:52878
#, javascript-format
msgid "%1$s have left the groupchat"
msgstr "%1$s குழுமத்தை விட்டு வெளியேறிவிட்டன"

#: dist/converse-no-dependencies.js:52880
#, javascript-format
msgid "%1$s are now moderators"
msgstr "%1$s இப்போது மதிப்பீட்டாளர்கள்"

#: dist/converse-no-dependencies.js:52882
#, javascript-format
