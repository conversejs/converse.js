#: dist/converse-no-dependencies.js:35359
msgid "A timeout occurred"
msgstr "நேரம் முடிந்தது"

#: dist/converse-no-dependencies.js:35919
msgid "You are blocked from sending messages."
msgstr "செய்திகளை அனுப்புவதிலிருந்து நீங்கள் தடுக்கப்பட்டுள்ளீர்கள்."

#: dist/converse-no-dependencies.js:36597
msgid "Timeout Error"
msgstr "காலக்கெடு பிழை"

#: dist/converse-no-dependencies.js:36598
msgid ""
"The server did not return your bookmarks within the allowed time. You can "
"reload the page to request them again."
msgstr ""
"அனுமதிக்கப்பட்ட நேரத்திற்குள் சேவையகம் உங்கள் புக்மார்க்குகளை திருப்பித் தரவில்லை. அவற்றை "
"மீண்டும் கோர பக்கத்தை மீண்டும் ஏற்றலாம்."

#: dist/converse-no-dependencies.js:38234
#, javascript-format
msgid "%1$s has gone offline"
msgstr "%1$s ஆஃப்லைனில் சென்றுவிட்டன"

#: dist/converse-no-dependencies.js:38236
#: dist/converse-no-dependencies.js:47986
#: dist/converse-no-dependencies.js:62355
#, javascript-format
msgid "%1$s has gone away"
msgstr "%1$s போய்விட்டன"

#: dist/converse-no-dependencies.js:38238
#, javascript-format
msgid "%1$s is busy"
msgstr "%1$s பிசியாக உள்ளது"

#: dist/converse-no-dependencies.js:38240
#, javascript-format
msgid "%1$s is online"
msgstr "%1$s ஆன்லைனில் உள்ளன"

#: dist/converse-no-dependencies.js:41398
msgid "Frequently used"
msgstr ""

#: dist/converse-no-dependencies.js:41399
msgid "Smileys and emotions"
msgstr "ச்மைலிகள் மற்றும் உணர்ச்சிகள்"

#: dist/converse-no-dependencies.js:41400
msgid "People"
msgstr "மக்கள்"

#: dist/converse-no-dependencies.js:41401
msgid "Activities"
msgstr "நடவடிக்கைகள்"

#: dist/converse-no-dependencies.js:41402
msgid "Travel"
msgstr "பயணம்"

#: dist/converse-no-dependencies.js:41403
msgid "Objects"
msgstr "பொருள்கள்"

#: dist/converse-no-dependencies.js:41404
msgid "Animals and nature"
msgstr "விலங்குகள் மற்றும் இயற்கை"

#: dist/converse-no-dependencies.js:41405
msgid "Food and drink"
msgstr "உணவு மற்றும் பானம்"

#: dist/converse-no-dependencies.js:41406
msgid "Symbols"
msgstr "குறியிடுகள்"

#: dist/converse-no-dependencies.js:41407
msgid "Flags"
msgstr "கொடிகள்"

#: dist/converse-no-dependencies.js:41408
msgid "Stickers"
msgstr "ச்டிக்கர்கள்"

#: dist/converse-no-dependencies.js:42858
msgid "Timeout while trying to fetch archived messages."
msgstr "காப்பகப்படுத்தப்பட்ட செய்திகளைப் பெற முயற்சிக்கும்போது நேரம் முடிந்தது."

#: dist/converse-no-dependencies.js:45536
#: dist/converse-no-dependencies.js:63398
msgid "You're not allowed to retract your message."
msgstr "உங்கள் செய்தியைத் திரும்பப் பெற உங்களுக்கு இசைவு இல்லை."

#: dist/converse-no-dependencies.js:45538
msgid ""
"Your retraction was not delivered because you're not present in the "
"groupchat."
msgstr "நீங்கள் குழுசாட்டில் இல்லாததால் உங்கள் பின்வாங்கல் வழங்கப்படவில்லை."

#: dist/converse-no-dependencies.js:45540
#: dist/converse-no-dependencies.js:63400
msgid "Sorry, an error occurred while trying to retract your message."
msgstr "மன்னிக்கவும், உங்கள் செய்தியைத் திரும்பப் பெற முயற்சிக்கும்போது பிழை ஏற்பட்டது."

#: dist/converse-no-dependencies.js:45545
msgid "Your message was not delivered because you weren't allowed to send it."
msgstr "உங்கள் செய்தி வழங்கப்படவில்லை, ஏனெனில் அதை அனுப்ப உங்களுக்கு இசைவு இல்லை."

#: dist/converse-no-dependencies.js:45547
msgid ""
"Your message was not delivered because you're not present in the groupchat."
msgstr "நீங்கள் குரூப்டில் இல்லாததால் உங்கள் செய்தி வழங்கப்படவில்லை."

#: dist/converse-no-dependencies.js:45549
#: dist/converse-no-dependencies.js:63407
msgid "Sorry, an error occurred while trying to send your message."
msgstr "மன்னிக்கவும், உங்கள் செய்தியை அனுப்ப முயற்சிக்கும்போது பிழை ஏற்பட்டது."

#: dist/converse-no-dependencies.js:45890
msgid "A timeout happened while trying to retract your message."
msgstr "உங்கள் செய்தியைத் திரும்பப் பெற முயற்சிக்கும் போது நேரம் முடிந்தது."

#: dist/converse-no-dependencies.js:46676
msgid "Sorry, an error happened while running the command."
msgstr "மன்னிக்கவும், கட்டளையை இயக்கும் போது பிழை ஏற்பட்டது."

#: dist/converse-no-dependencies.js:46676
#: dist/converse-no-dependencies.js:125705
msgid "Check your browser's developer console for details."
msgstr "விவரங்களுக்கு உங்கள் உலாவியின் உருவாக்குபவர் கன்சோலை சரிபார்க்கவும்."

#: dist/converse-no-dependencies.js:46696
#: dist/converse-no-dependencies.js:46714
msgid "Error: couldn't find a groupchat participant based on your arguments"
msgstr ""
"பிழை: உங்கள் வாதங்களின் அடிப்படையில் ஒரு குழுசாட் பங்கேற்பாளரைக் கண்டுபிடிக்க முடியவில்லை"

#: dist/converse-no-dependencies.js:46704
msgid "Error: found multiple groupchat participant based on your arguments"
msgstr "பிழை: உங்கள் வாதங்களின் அடிப்படையில் பல குரூப்சாட் பங்கேற்பாளரைக் கண்டறிந்தார்"

#: dist/converse-no-dependencies.js:46729
#, javascript-format
msgid ""
"Error: the \"%1$s\" command takes two arguments, the user's nickname and "
"optionally a reason."
msgstr ""
"பிழை: \"%1$s\" கட்டளை இரண்டு வாதங்களை எடுக்கும், பயனரின் புனைப்பெயர் மற்றும் விருப்பமாக "
"ஒரு காரணம்."

#: dist/converse-no-dependencies.js:46814
msgid ""
"Forbidden: you do not have the necessary affiliation in order to do that."
msgstr "தடைசெய்யப்பட்டுள்ளது: அதைச் செய்ய உங்களுக்கு தேவையான தொடர்பு இல்லை."

#: dist/converse-no-dependencies.js:46845
msgid "Forbidden: you do not have the necessary role in order to do that."
msgstr "தடைசெய்யப்பட்டுள்ளது: அதைச் செய்ய உங்களுக்கு தேவையான பங்கு இல்லை."

#: dist/converse-no-dependencies.js:47194
msgid "You're not allowed to register yourself in this groupchat."
msgstr "இந்த குழுவில் உங்களை பதிவு செய்ய உங்களுக்கு இசைவு இல்லை."

#: dist/converse-no-dependencies.js:47196
msgid ""
"You're not allowed to register in this groupchat because it's members-only."
msgstr ""
"இந்த குழுவில் பதிவு செய்ய உங்களுக்கு இசைவு இல்லை, ஏனெனில் அது உறுப்பினர்கள் மட்டுமே."

#: dist/converse-no-dependencies.js:47530
#, javascript-format
msgid "Topic set by %1$s"
msgstr "தலைப்பு %1$s ஆல் அமைக்கப்பட்டுள்ளது"

#: dist/converse-no-dependencies.js:47530
#, javascript-format
msgid "Topic cleared by %1$s"
msgstr "தலைப்பு %1$s ஆல் அழிக்கப்பட்டது"

