#: dist/converse-no-dependencies.js:52845
#: dist/converse-no-dependencies.js:70423
#, javascript-format
msgid "%1$s has stopped typing"
msgstr "%1$s தட்டச்சு செய்வதை நிறுத்திவிட்டன"

#: dist/converse-no-dependencies.js:52849
#, javascript-format
