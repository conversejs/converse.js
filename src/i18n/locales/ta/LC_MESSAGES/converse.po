msgstr "%1$s முடக்கப்பட்டுள்ளன"

#: dist/converse-no-dependencies.js:48420
#, javascript-format
msgid "%1$s has been banned by %2$s"
msgstr "%1$s %2$s ஆல் தடைசெய்யப்பட்டுள்ளது"

#: dist/converse-no-dependencies.js:48420
#, javascript-format
msgid "%1$s has been banned"
msgstr "%1$s தடை செய்யப்பட்டுள்ளன"

#: dist/converse-no-dependencies.js:48422
#, javascript-format
msgid "%1$s's nickname has changed"
msgstr "%1$s இன் புனைப்பெயர் மாறிவிட்டது"

#: dist/converse-no-dependencies.js:48424
#, javascript-format
msgid "%1$s has been kicked out by %2$s"
msgstr "%1$s %2$s ஆல் வெளியேற்றப்பட்டுள்ளது"

#: dist/converse-no-dependencies.js:48424
#, javascript-format
msgid "%1$s has been kicked out"
msgstr "%1$s வெளியேற்றப்பட்டுள்ளன"

#: dist/converse-no-dependencies.js:48426
#, javascript-format
msgid "%1$s has been removed because of an affiliation change"
msgstr "இணைப்பு மாற்றம் காரணமாக %1$s அகற்றப்பட்டுள்ளன"

#: dist/converse-no-dependencies.js:48428
#, javascript-format
msgid "%1$s has been removed for not being a member"
msgstr "உறுப்பினராக இல்லாததால் %1$s அகற்றப்பட்டுள்ளன"

#: dist/converse-no-dependencies.js:48451
#, javascript-format
msgid "%1$s is no longer an admin of this groupchat"
msgstr "%1$s இனி இந்த குழுமத்தின் நிர்வாகியாக இருக்காது"

#: dist/converse-no-dependencies.js:48456
#, javascript-format
msgid "%1$s is no longer an owner of this groupchat"
msgstr "%1$s இனி இந்த குரூபியின் உரிமையாளர் அல்ல"

#: dist/converse-no-dependencies.js:48461
#, javascript-format
msgid "%1$s is no longer banned from this groupchat"
msgstr "இந்த குரூப்சாட்டில் இருந்து %1$s இனி தடை செய்யப்படாது"

#: dist/converse-no-dependencies.js:48467
#, javascript-format
msgid "%1$s is no longer a member of this groupchat"
msgstr "%1$s இனி இந்த குரூப்சாட்டின் உறுப்பினராக இல்லை"

#: dist/converse-no-dependencies.js:48473
#, javascript-format
msgid "%1$s is now a member of this groupchat"
msgstr "%1$s இப்போது இந்த குழுமத்தின் உறுப்பினராக உள்ளன"

#: dist/converse-no-dependencies.js:48479
#, javascript-format
msgid "%1$s is now an %2$s of this groupchat"
msgstr "%1$s இப்போது இந்த குழுமத்தின் %2$s ஆகும்"

#: dist/converse-no-dependencies.js:48605
msgid ""
"The nickname you chose is reserved or currently in use, please choose a "
"different one."
msgstr ""
"நீங்கள் தேர்ந்தெடுத்த புனைப்பெயர் ஒதுக்கப்பட்டுள்ளது அல்லது தற்போது பயன்பாட்டில் உள்ளது, "
"தயவுசெய்து வேறு ஒன்றைத் தேர்வுசெய்க."

#: dist/converse-no-dependencies.js:48631
msgid "Password incorrect"
msgstr "கடவுச்சொல் தவறானது"

#: dist/converse-no-dependencies.js:48638
msgid "You are not on the member list of this groupchat."
msgstr "இந்த குழுமத்தின் உறுப்பினர் பட்டியலில் நீங்கள் இல்லை."

#: dist/converse-no-dependencies.js:48646
msgid "You are not allowed to create new groupchats."
msgstr "புதிய குழு அரட்டைகளை உருவாக்க உங்களுக்கு இசைவு இல்லை."

#: dist/converse-no-dependencies.js:48649
msgid "Your nickname doesn't conform to this groupchat's policies."
msgstr "உங்கள் புனைப்பெயர் இந்த குரூப்சாட்டின் கொள்கைகளுக்கு இணங்கவில்லை."

#: dist/converse-no-dependencies.js:48664
msgid "This groupchat does not (yet) exist."
msgstr "இந்த குரூப்சாட் (இன்னும்) இல்லை."

#: dist/converse-no-dependencies.js:48667
msgid "This groupchat has reached its maximum number of participants."
msgstr "இந்த குரூப்சாட் அதன் அதிகபட்ச பங்கேற்பாளர்களை எட்டியுள்ளது."

#: dist/converse-no-dependencies.js:48670
msgid "Remote server not found"
msgstr "தொலை சேவையகம் கிடைக்கவில்லை"

#: dist/converse-no-dependencies.js:48673
msgid "You're not allowed to enter this groupchat"
msgstr "இந்த குழுமத்திற்குள் நுழைய உங்களுக்கு இசைவு இல்லை"

#: dist/converse-no-dependencies.js:48676
msgid "An error happened while trying to enter this groupchat"
msgstr "இந்த குழுமத்தை உள்ளிட முயற்சிக்கும் போது பிழை ஏற்பட்டது"

#: dist/converse-no-dependencies.js:50168
msgid "This groupchat is not anonymous"
msgstr "இந்த குரூப்சாட் அநாமதேயமானது அல்ல"

#: dist/converse-no-dependencies.js:50169
msgid "This groupchat now shows unavailable members"
