msgstr "%1$s بولسا %2$s تەرىپىدىن چەكلەندى"

#: dist/converse-no-dependencies.js:59163
#, javascript-format
msgid "%1$s has been banned"
msgstr "%1$s چەكلەندى"

#: dist/converse-no-dependencies.js:59165
#, javascript-format
