#: dist/converse-no-dependencies.js:59167
#, javascript-format
msgid "%1$s has been kicked out"
msgstr "%1$s بولسا چىقىرۋېتىلدى"

#: dist/converse-no-dependencies.js:59169
#, javascript-format
