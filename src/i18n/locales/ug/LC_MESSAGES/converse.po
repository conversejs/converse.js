#: dist/converse-no-dependencies.js:26570
#: dist/converse-no-dependencies.js:58725
#, javascript-format
msgid "%1$s is typing"
msgstr "%1$s يېزىۋاتىدۇ"

#: dist/converse-no-dependencies.js:26572
#: dist/converse-no-dependencies.js:58727
#, javascript-format
msgid "%1$s has stopped typing"
msgstr "%1$s يېزىشنى توختاتتى"

#: dist/converse-no-dependencies.js:26574
#: dist/converse-no-dependencies.js:58729
#: dist/converse-no-dependencies.js:60649
#, javascript-format
msgid "%1$s has gone away"
msgstr "%1$s كىتىپ قالدى"

#: dist/converse-no-dependencies.js:27055
#: dist/converse-no-dependencies.js:27073
msgid "Sorry, looks like file upload is not supported by your server."
msgstr ""
"كەچۈرۈڭ، سىزنىڭ مۇلازىمىتىرىڭىز ھۆججەت چىقىرىشنى قوللىمايدىغاندەك تۇرىدۇ."

#: dist/converse-no-dependencies.js:27104
#, javascript-format
msgid ""
"The size of your file, %1$s, exceeds the maximum allowed by your server."
msgstr ""
"ھۆججىتىڭىزنىڭ سىغىمى، %1$s، مۇلازىمېتىر يول قويىدىغان ئەڭ چوڭ قىممەتتىن "
"ئېشىپ كەتتى."

#: dist/converse-no-dependencies.js:27104
#, javascript-format
msgid ""
"The size of your file, %1$s, exceeds the maximum allowed by your server, "
"which is %2$s."
msgstr ""
"سىزنىڭ ھۆججىتىڭىزنىڭ سىغىمى، %1$s، مۇلازىمىتىر يول قويغان %2$s سىغىمدىن "
"ئېشىپ كەتتى."

#: dist/converse-no-dependencies.js:27680
#: dist/converse-no-dependencies.js:56273
msgid "You're not allowed to retract your message."
msgstr "سىز ئۇچۇرىڭىزنى قايتۇرۋېلىشقا رۇخسەت قىلىنمىدىڭىز."

#: dist/converse-no-dependencies.js:27682
#: dist/converse-no-dependencies.js:56277
msgid "Sorry, an error occurred while trying to retract your message."
msgstr "كەچۈرۈڭ، ئۇچۇرىڭىزنى قايتۇرۋاتقاندا بىر خاتالىق كۆرۈلدى."

#: dist/converse-no-dependencies.js:27687
msgid "You're not allowed to send a message."
msgstr "سىز ئۇچۇر يوللاشقا رۇخسەت قىلىنمىدىڭىز."

#: dist/converse-no-dependencies.js:27689
#: dist/converse-no-dependencies.js:56286
msgid "Sorry, an error occurred while trying to send your message."
msgstr "كەچۈرۈڭ، ئۇچۇرىڭىزنى يوللاۋاتقاندا بىر خاتالىق كۆرۈلدى."

#: dist/converse-no-dependencies.js:31277
#, javascript-format
msgid ""
"Sorry, we're unable to send an encrypted message because %1$s requires you "
"to be subscribed to their presence in order to see their OMEMO information"
msgstr ""
"كەچۈرۈڭ، بىز بىر شىفىرلانغان ئۇچۇرنى يوللىيالمىدۇق چۈنكى %1$s نىڭ OMEMO "
"ئۇچۇرىنى كۆرۈش ئۈچۈەن ئۇلار سىزنىڭ ئۇلارنىڭ مەۋجۇتلۇقىغا مۇشتەرى بۇلىشىڭىزنى "
"تەلەپ قىلىدۇ"

#: dist/converse-no-dependencies.js:31279
#, javascript-format
msgid ""
"Sorry, we're unable to send an encrypted message because the remote server "
"for %1$s could not be found"
msgstr ""
"كەچۈرۈڭ، بىز شىفىرلانغان ئۇچۇرنى ئەۋەتەلمىدۇق چۈنكى %1$s نىڭ يىراقتىكى "
"مۇلازىمىتېرى تېپىلمىدى"

#: dist/converse-no-dependencies.js:31281
msgid "Unable to send an encrypted message due to an unexpected error."
msgstr ""
"ئويلىمىغان خاتالىق سەۋەبىدىن بىر شىفىرلانغان ئۇچۇرنى ئەۋەتكىلى بولمىدى."

#: dist/converse-no-dependencies.js:31284
#: dist/converse-no-dependencies.js:31286
#: dist/converse-no-dependencies.js:94998
#: dist/converse-no-dependencies.js:95002
#: dist/converse-no-dependencies.js:95107
#: dist/converse-no-dependencies.js:100317
#: dist/converse-no-dependencies.js:100458
#: dist/converse-no-dependencies.js:100523
#: dist/converse-no-dependencies.js:111681
#: dist/converse-no-dependencies.js:122316
#: dist/converse-no-dependencies.js:122326
#: dist/converse-no-dependencies.js:125898
#: dist/converse-no-dependencies.js:131550
#: dist/converse-no-dependencies.js:135467
msgid "Error"
msgstr "خاتالىق"

#: dist/converse-no-dependencies.js:31591
msgid ""
"Sorry, no devices found to which we can send an OMEMO encrypted message."
msgstr ""
"كەچۈرۈڭ، بىز OMEMO بىلەن شىفىرلانغان ئۇچۇرنى ئەۋەتىدىغان ھېچقانداق ئەسۋاپ "
"تېپلىمىدى."

#: dist/converse-no-dependencies.js:31601
msgid ""
"Cannot use OMEMO in this groupchat — it must be non-anonymous and members-"
"only."
msgstr ""

#: dist/converse-no-dependencies.js:32554
msgid ""
"This is an OMEMO encrypted message which your client doesn’t seem to "
"support. Find more information on https://conversations.im/omemo"
msgstr ""
"بۇ بولسا سىزنىڭ خېرىدارىڭىز قوللىماسلىقى مۇمكىن بولغان OMEMO شىفىرلىق ئۇچۇر. "
"تېخىمۇ كۆپ ئۇچۇرلارنى بۇ يەردىن كۆرۈڭ\n"
"https://conversations.im/omemo"

#: dist/converse-no-dependencies.js:32673
#, javascript-format
msgid ""
"%1$s doesn't appear to have a client that supports OMEMO. Encrypted chat "
"will no longer be possible in this grouchat."
msgstr ""
"%1$sدا ‎OMEMO قوللايدىغان بىرەر خېرىدار يوقتەك قىلىدۇ. شىفىرلانغان ئۇچۇر "
"ئەمدى بۇ توپپاراڭدا مۇمكىن بولمايدۇ."

#: dist/converse-no-dependencies.js:32793
msgid ""
"Received an OMEMO encrypted message which could not be decrypted, because it "
"was not encrypted for this device."
msgstr ""

#: dist/converse-no-dependencies.js:32801
msgid "Sorry, could not decrypt a received OMEMO message due to an error."
msgstr ""
"كەچۈرۈڭ، بىر خاتالىق سەۋەبىدىن تاپشۇرۋالغان بىر OMEMO ئۇچۇرىنى "
"شىفىرسىزلىيالمىدۇق."

#: dist/converse-no-dependencies.js:32836
msgid ""
"Sorry, could not decrypt a received OMEMO message because we don't have the "
"XMPP address for that user."
msgstr ""
"كەچۈرۈڭ، تاپشۇرۋالغان بىر OMEMO ئۇچۇرىنى شىفىرسىلىيالمىدۇق چۈنكى بىزدە ئۇ "
"ئىشلەتكۈچىنىڭ XMPP ئادىرسى يوق."

#: dist/converse-no-dependencies.js:49254
msgid "Could not automatically determine a connection URL"
msgstr "باغلانما تور ئادرېسىنى ئۆزلۈكىدىن جەزملىيەلمەيدۇ"

#: dist/converse-no-dependencies.js:49590
#: dist/converse-no-dependencies.js:49643
msgid "An error occurred while connecting to the chat server."
msgstr "پاراڭ مۇلازىمېتىرىغا ئۇلاۋاتقاندا خاتالىق كۆرۈلدى."

#: dist/converse-no-dependencies.js:49650
msgid "Your XMPP address and/or password is incorrect. Please try again."
msgstr "سىزنىڭ XMPP ئادىرسىڭىز ياكى/ مەخپىي نۇمۇرىڭىز خاتا. قايتا سىناپ بېقىڭ."

#: dist/converse-no-dependencies.js:49659
#, javascript-format
msgid "We could not connect to %1$s, is your XMPP address correct?"
msgstr "%1$s غا باغلىنالمايمىز، XMPP ئادرېسىڭىز توغرىمۇ؟"

#: dist/converse-no-dependencies.js:49661
msgid "The XMPP server rejected the connection because of a policy violation"
msgstr ""

#: dist/converse-no-dependencies.js:49663
msgid "The XMPP server did not offer a supported authentication mechanism"
msgstr ""
"بۇ XMPP مۇلازىمىتىرى بىرەر قوللايدىغان كىملىكىنى دەلىللەش مېخانىزىمىنى "
"تەمىنلىمىدى"

#: dist/converse-no-dependencies.js:53489
msgid "Undecryptable OMEMO message"
msgstr "يەشكىلى بولمايدىغان OMEMOلۇق ئۇچۇر"

#: dist/converse-no-dependencies.js:53589
msgid "Sorry, could not determine upload URL."
msgstr "كەچۈرۈڭ، چىقىرىش ئۇلىنىشىنى تاپالمىدى."

#: dist/converse-no-dependencies.js:53606
msgid "Sorry, could not determine file upload URL."
msgstr "كەچۈرۈڭ، ھۆججەت چىقىرىش ئۇلىنىشىنى تاپالمىدى."

#: dist/converse-no-dependencies.js:53682
#, fuzzy, javascript-format
msgid ""
"Sorry, could not successfully upload your file. Your server’s response: "
"\"%1$s\""
msgstr ""
"كەچۈرۈڭ ھۆججىتىڭىزنى مۇۋەپپەقىيەتلىك يۈكلىيەلمىدى. مۇلازىمىتىرىڭىزنىڭ "
"جاۋابى: «%1$s»"

#: dist/converse-no-dependencies.js:53684
#, fuzzy
msgid "Sorry, could not successfully upload your file."
msgstr "كەچۈرۈڭ، ھۆججىتىڭىزنى مۇۋاپپىقىيەتلىك چىقىرالمىدۇق."

